      <column caption='Profit' datatype='real' name='[Calculation_0816136768352256]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total_Price]) - SUM([Food_Cost])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0816136768581633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total_Price]) / COUNTD([Order_No])' />
